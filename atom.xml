    <author>
      <name>放</name>
    </author>
    <category term="技术" scheme="https://fangjzsp.github.io/fang_blog/categories/%E6%8A%80%E6%9C%AF/"/>
    <category term="Hexo" scheme="https://fangjzsp.github.io/fang_blog/tags/Hexo/"/>
